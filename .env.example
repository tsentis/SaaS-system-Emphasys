# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- Database ----
POSTGRES_USER=emphasys
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=emphasys
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL is derived by the backend from the parts above; override if needed:
# DATABASE_URL=postgresql+psycopg://emphasys:change-me-in-prod@db:5432/emphasys

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0

# ---- Object storage (MinIO in dev, S3 in prod) ----
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=emphasys-documents
S3_REGION=eu-central-1

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_EXTRACTION_MODEL=claude-opus-4-8
ANTHROPIC_BULK_MODEL=claude-sonnet-4-6

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# ---- Security ----
SECRET_KEY=change-me-generate-a-long-random-string
CORS_ORIGINS=http://localhost:3000
